# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dawat-restaurant

# JWT Secret (must be strong and unique for production)
JWT_SECRET=your-secure-jwt-secret-here-change-in-production

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Admin seed credentials (used by createAdmin script only)
ADMIN_INITIAL_EMAIL=admin@dawatrestaurant.com
ADMIN_INITIAL_PASSWORD=change-this-strong-password

# ─── NEW: Redis (optional — app works without it, caching disabled) ───
# Get free at: https://upstash.com (Free tier: 10K commands/day)
REDIS_URL=redis://default:your-password@your-host.upstash.io:6379

# ─── NEW: Email / SMTP (optional — app works without it, emails disabled) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
RESTAURANT_EMAIL=owner@dawatrestaurant.com

# ─── NEW: App Config ───
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NODE_ENV=development
LOG_LEVEL=info
